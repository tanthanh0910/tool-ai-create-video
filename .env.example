# Video Settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
FPS=24
SECONDS_PER_IMAGE=5

# TTS Settings (Edge TTS - mien phi)
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_RATE=+0%

# Ollama Settings (local LLM - mien phi)
OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434

# Hugging Face (free - lay token tai https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Pexels API (free - dang ky tai https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_key_here

# Output
OUTPUT_DIR=./output
TEMP_DIR=./temp
MAX_PARALLEL_VIDEOS=3
